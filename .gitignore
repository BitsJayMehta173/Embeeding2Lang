# ─────────────────────────────────────────────
#  Cross-Lingual Semantic Guardrail — .gitignore
#  Only Python scripts, README, and tiny data
#  files (dictionary + eval set) are committed.
#  Everything else is auto-generated by the pipeline.
# ─────────────────────────────────────────────

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.env
venv/
.venv/
env/

# ── FastText model binaries ───────────────────
# These are GB-scale; regenerated by train_embeddings.py
models/*.bin
models/*.bin.syn1neg.npy
models/*.bin.wv.vectors_ngrams.npy
models/*.bin.wv.vectors_vocab.npy
models/*.bin.trainables.syn1neg.npy

# ── H4 CP-CLE aligned KeyedVectors ───────────
# Regenerated by cp_cle_optimizer.py
models/*.kv
models/*.kv.vectors.npy

# Keep the models/ folder itself (for README clarity)
!models/.gitkeep

# ── Large training corpora ────────────────────
# Regenerated by data_prep.py + build_datasets.py
data/en_corpus.txt
data/hi_corpus.txt
data/translated_corpus.txt
data/pseudo_context_corpus.txt

# Keep the small, essential data files (< 1 MB)
!data/en-hi.txt
!data/eval_pairs.json
!data/.gitkeep

# ── HuggingFace / Gensim download caches ──────
# mBERT (~714MB) and GloVe are auto-downloaded at runtime
.cache/
~/.cache/huggingface/
huggingface/
gensim-data/
*.cache

# ── Fonts ─────────────────────────────────────
# NotoSansDevanagari downloaded at runtime if needed
fonts/

# ── Result PDFs (large, generated files) ──────
results/*.pdf
results/*.pkl

# Keep plots and summary CSVs (small, useful previews)
!results/Similarity_Distributions_H4.png
!results/F1_vs_Threshold.png
!results/similarity_distributions.png
!results/augmented_evaluation_summary.csv
!results/Edge_Computing_Benchmark.md
!results/.gitkeep

# ── OS & IDE ──────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.code-workspace

# ── Jupyter ───────────────────────────────────
.ipynb_checkpoints/
*.ipynb
