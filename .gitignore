# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.env
venv/
.venv/

# Large model files (FastText binaries are too big for GitHub)
models/*.bin
models/*.wv
models/*.vectors.npy
models/*.syn1neg.npy

# H4 KeyedVectors (generated by cp_cle_optimizer.py)
models/*.kv
models/*.kv.vectors.npy

# Large data corpus files
data/*_corpus.txt
data/en_sentences.txt
data/hi_sentences.txt

# Keep the dictionary and eval set (small, useful for reproducibility)
!data/en-hi.txt
!data/eval_pairs.json

# Results (plots are fine, large PDFs are not)
results/*.pdf
results/*.pkl

# Keep the distribution plot (referenced in README)
!results/Similarity_Distributions_H4.png
!results/F1_vs_Threshold.png
!results/augmented_evaluation_summary.csv
!results/Edge_Computing_Benchmark.md

# Fonts (large TTF)
fonts/

# GloVe / Gensim download cache
*.cache
gensim-data/

# IDE
.vscode/
.idea/
*.code-workspace

# OS
.DS_Store
Thumbs.db

